<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Task 1: Gallery — Android 13+ ใช้ READ_MEDIA_IMAGES, เวอร์ชันเก่าใช้ READ_EXTERNAL_STORAGE -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme._164_LabLearnAndriod"
        tools:targetApi="31">
        <activity
            android:name=".SharedPreferencesActivity"
            android:exported="false"
            android:label="@string/title_activity_shared_preferences"
            android:theme="@style/Theme._164_LabLearnAndriod" />
        <activity
            android:name=".MenuActivity"
            android:exported="true"
            android:label="@string/title_activity_menu"
            android:theme="@style/Theme._164_LabLearnAndriod">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".LstActivity"
            android:exported="false"
            android:label="@string/title_activity_lst"
            android:theme="@style/Theme._164_LabLearnAndriod" />
        <activity
            android:name=".MainActivity2"
            android:exported="false"
            android:label="@string/title_activity_main2"
            android:theme="@style/Theme._164_LabLearnAndriod">

            <!-- <intent-filter> -->
            <!-- <action android:name="android.intent.action.MAIN" /> -->


            <!-- <category android:name="android.intent.category.LAUNCHER" /> -->
            <!-- </intent-filter> -->
        </activity>
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme._164_LabLearnAndriod" />
        <!-- Task 1: Camera Permission + TakePicturePreview -->
        <activity
            android:name=".CameraActivity"
            android:exported="false"
            android:label="Camera Task"
            android:theme="@style/Theme._164_LabLearnAndriod" />
        <!-- Task 2/3: Accelerometer via ViewModel + StateFlow -->
        <activity
            android:name=".SensorActivity"
            android:exported="false"
            android:label="Sensor Task"
            android:theme="@style/Theme._164_LabLearnAndriod" />
        <!-- Task 1 (Lab ใหม่): Gallery + Permission Flow -->
        <activity
            android:name=".GalleryActivity"
            android:exported="false"
            android:label="Gallery Task"
            android:theme="@style/Theme._164_LabLearnAndriod" />

        <!-- Mission 1: Animation -->
        <activity
            android:name=".AnimationActivity"
            android:exported="false"
            android:label="Animation &amp; Motion" />

        <!-- Mission 2: Complex Lists & Pagination -->
        <activity
            android:name=".Part2Activity"
            android:exported="false"
            android:label="Part 2: Complex Lists" />

        <!-- Mission 3: Graphics & Canvas -->
        <activity
            android:name=".CanvasActivity"
            android:exported="false"
            android:label="Canvas Graphics" />

        <!-- Mission 4: Gestures -->
        <activity
            android:name=".GestureActivity"
            android:exported="false"
            android:label="Advanced Gestures" />

        <!-- Mission 5: Side Effects -->
        <activity
            android:name=".SideEffectActivity"
            android:exported="false"
            android:label="Side Effects" />

        <!-- Mission 6: View Interop -->
        <activity
            android:name=".WebViewActivity"
            android:exported="false"
            android:label="View Interoperability" />

        <!-- Mission 7: Transitions -->
        <activity
            android:name=".TransitionActivity"
            android:exported="false"
            android:label="Activity Transitions" />
        <activity
            android:name=".DetailActivity"
            android:exported="false"
            android:label="Detail Screen" />

        <!-- Mission 8: Adaptive Layouts -->
        <activity
            android:name=".AdaptiveLayoutActivity"
            android:exported="false"
            android:label="Adaptive Layout" />

        <!-- Mission 9: Collapsing Toolbar -->
        <activity
            android:name=".CollapsingToolbarActivity"
            android:exported="false"
            android:label="Collapsing Toolbar" />

        <!-- Mission 10: App Widget -->
        <receiver
            android:name=".ExampleAppWidget"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/example_app_widget_info" />
        </receiver>

    </application>

</manifest>

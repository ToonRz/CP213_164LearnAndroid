<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme._164_LabLearnAndriod"
        tools:targetApi="31">
        <activity
            android:name=".SharedPreferencesActivity"
            android:exported="false"
            android:label="@string/title_activity_shared_preferences"
            android:theme="@style/Theme._164_LabLearnAndriod" />
        <activity
            android:name=".MenuActivity"
            android:exported="true"
            android:label="@string/title_activity_menu"
            android:theme="@style/Theme._164_LabLearnAndriod">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".LstActivity"
            android:exported="false"
            android:label="@string/title_activity_lst"
            android:theme="@style/Theme._164_LabLearnAndriod" />
        <activity
            android:name=".MainActivity2"
            android:exported="false"
            android:label="@string/title_activity_main2"
            android:theme="@style/Theme._164_LabLearnAndriod">

            <!-- <intent-filter> -->
            <!-- <action android:name="android.intent.action.MAIN" /> -->


            <!-- <category android:name="android.intent.category.LAUNCHER" /> -->
            <!-- </intent-filter> -->
        </activity>
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme._164_LabLearnAndriod" />
        <!-- Task 1: Camera Permission + TakePicturePreview -->
        <activity
            android:name=".CameraActivity"
            android:exported="false"
            android:label="Camera Task"
            android:theme="@style/Theme._164_LabLearnAndriod" />
        <!-- Task 2/3: Accelerometer via ViewModel + StateFlow -->
        <activity
            android:name=".SensorActivity"
            android:exported="false"
            android:label="Sensor Task"
            android:theme="@style/Theme._164_LabLearnAndriod" />
    </application>

</manifest>